# Server
PORT=3000
HOST=127.0.0.1

# Tesco XAPI configuration
TESCO_MANGO_URL=https://xapi.tesco.com/
TESCO_SUGGESTION_URL=https://search.api.tesco.com/search/suggestion/
TESCO_LOCALE=en-IE
TESCO_REGION=IE

# Fill these from a currently logged-in Tesco browser session.
# Do not commit real values.
TESCO_MANGO_API_KEY=replace-with-current-api-key
TESCO_AUTHORIZATION=Bearer replace-with-current-token
TESCO_AUTH_COOKIE_HEADER="OAuth.TokensExpiryTime=replace-with-encoded-expiry-json; replace-with-other-auth-cookies"
TESCO_SOFT_REFRESH_SIGN_IN_URL=https://www.tesco.ie/account/login/en-IE
TESCO_AUTH_REFRESH_FROM_URL=https://www.tesco.ie/shop/en-IE

# Optional Tesco headers. Leave unset unless the browser request includes them.
# TESCO_TRANSACTION_PURPOSE=
# TESCO_RELEASE_BRANCH=
